{
  "openapi": "3.0.4",
  "info": {
    "title": "CollegeSchedule.Api.Mihalev",
    "version": "1.0"
  },
  "paths": {
    "/api/schedule/{groupName}": {
      "get": {
        "tags": [
          "Schedule"
        ],
        "parameters": [
          {
            "name": "groupName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ScheduleByDateDto"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ScheduleByDateDto"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ScheduleByDateDto"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LessonDto": {
        "type": "object",
        "properties": {
          "lessonNumber": {
            "type": "integer",
            "format": "int32"
          },
          "time": {
            "type": "string",
            "nullable": true
          },
          "groupParts": {
            "type": "object",
            "properties": {
              "FULL": {
                "$ref": "#/components/schemas/LessonPartDto"
              },
              "SUB1": {
                "$ref": "#/components/schemas/LessonPartDto"
              },
              "SUB2": {
                "$ref": "#/components/schemas/LessonPartDto"
              }
            },
            "additionalProperties": false,
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LessonPartDto": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "nullable": true
          },
          "teacher": {
            "type": "string",
            "nullable": true
          },
          "teacherPosition": {
            "type": "string",
            "nullable": true
          },
          "classroom": {
            "type": "string",
            "nullable": true
          },
          "building": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ScheduleByDateDto": {
        "type": "object",
        "properties": {
          "lessonDate": {
            "type": "string",
            "format": "date-time"
          },
          "weekday": {
            "type": "string",
            "nullable": true
          },
          "lessons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LessonDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Schedule"
    }
  ]
}